.login-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  position: relative;
  overflow: hidden;
}

.login-container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: float 25s infinite linear;
}

.login-container::after {
  content: '';
  position: absolute;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(102,126,234,0.15) 0%, transparent 70%);
  border-radius: 50%;
  top: -100px;
  right: -100px;
  pointer-events: none;
}

@keyframes float {
  0% { transform: translate(0, 0) rotate(0deg); }
  100% { transform: translate(-50px, -50px) rotate(360deg); }
}

.login-form {
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 3rem;
  border-radius: 24px;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.1);
  width: 100%;
  max-width: 420px;
  text-align: center;
  position: relative;
  z-index: 1;
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.login-logo {
  height: 80px;
  margin-bottom: 1.5rem;
  filter: drop-shadow(0 4px 12px rgba(102, 126, 234, 0.4));
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  padding: 12px;
}

.login-form h2 {
  margin-bottom: 2rem;
  color: #fff;
  font-size: 2rem;
  font-weight: 300;
  letter-spacing: 2px;
}

.login-form input {
  width: 100%;
  padding: 1rem 1.2rem;
  margin-bottom: 1.2rem;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  font-size: 1rem;
  box-sizing: border-box;
  background: rgba(255,255,255,0.08);
  color: #fff;
  transition: all 0.3s ease;
  outline: none;
}

.login-form input:focus {
  border-color: #667eea;
  background: rgba(255,255,255,0.12);
  box-shadow: 0 0 0 3px rgba(102,126,234,0.2);
}

.login-form input::placeholder {
  color: rgba(255,255,255,0.4);
  font-weight: 300;
}

.user-type-select {
  width: 100%;
  padding: 1rem;
  margin-bottom: 1.5rem;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  font-size: 1rem;
  box-sizing: border-box;
  background: rgba(255,255,255,0.08);
  color: #fff;
  transition: all 0.3s ease;
  outline: none;
  cursor: pointer;
}

.user-type-select:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102,126,234,0.2);
}

.login-form button[type="submit"] {
  width: 100%;
  padding: 1rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12px;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-top: 0.5rem;
  box-shadow: 0 8px 25px rgba(102,126,234,0.35);
}

.login-form button[type="submit"]:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 35px rgba(102, 126, 234, 0.5);
}

.login-form button[type="submit"]:active {
  transform: translateY(-1px);
}

.toggle-form {
  margin-top: 1.5rem;
  color: rgba(255,255,255,0.55);
  font-size: 0.9rem;
}

.toggle-form span {
  color: #a78bfa;
  cursor: pointer;
  font-weight: 500;
  transition: color 0.3s ease;
}

.toggle-form span:hover {
  color: #c4b5fd;
  text-decoration: underline;
}

.forgot-password {
  margin-top: 1rem;
  color: #a78bfa;
  font-size: 0.9rem;
  cursor: pointer;
  transition: color 0.3s ease;
}

.forgot-password:hover {
  color: #c4b5fd;
  text-decoration: underline;
}

.field-error {
  color: #fca5a5;
  font-size: 0.8rem;
  margin: -0.8rem 0 1rem 0.25rem;
  text-align: left;
}

.password-strength {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin: -0.8rem 0 1rem;
}

.password-strength-bar {
  flex: 1;
  height: 4px;
  background: rgba(255,255,255,0.1);
  border-radius: 4px;
  overflow: hidden;
}

.password-strength-bar div {
  height: 100%;
  border-radius: 4px;
  transition: width 0.3s ease, background 0.3s ease;
}

.password-strength span {
  font-size: 0.8rem;
  font-weight: 600;
  white-space: nowrap;
}

.login-toast {
  position: fixed;
  top: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.5rem;
  border-radius: 12px;
  font-size: 0.95rem;
  font-weight: 500;
  box-shadow: 0 8px 30px rgba(0,0,0,0.3);
  z-index: 9999;
  animation: slideDown 0.3s ease;
  max-width: 420px;
  width: 90%;
}

.login-toast--error {
  background: #2d1a1a;
  border: 1px solid rgba(244,63,94,0.4);
  color: #fca5a5;
}

.login-toast--success {
  background: #1a2d1e;
  border: 1px solid rgba(16,185,129,0.4);
  color: #6ee7b7;
}

.login-toast--info {
  background: #1a1f2d;
  border: 1px solid rgba(59,130,246,0.4);
  color: #93c5fd;
}

.login-toast-icon {
  font-size: 1.1rem;
  font-weight: 700;
  flex-shrink: 0;
}

.login-toast-close {
  margin-left: auto;
  background: none;
  border: none;
  color: inherit;
  font-size: 1.2rem;
  cursor: pointer;
  opacity: 0.7;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
}
.login-toast-close:hover { opacity: 1; }

@keyframes slideDown {
  from { opacity: 0; transform: translateX(-50%) translateY(-12px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.login-divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 1rem 0;
  color: rgba(255,255,255,0.3);
  font-size: 0.85rem;
}
.login-divider::before,
.login-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,0.12);
}

.google-btn {
  width: 100%;
  padding: 0.85rem;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  background: rgba(255,255,255,0.08);
  color: #fff;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  transition: all 0.3s ease;
  margin-top: 0;
}
.google-btn:hover {
  background: rgba(255,255,255,0.14);
  border-color: rgba(255,255,255,0.3);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

.login-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99999;
  backdrop-filter: blur(8px);
}

.login-modal-box {
  background: rgba(30, 25, 60, 0.95);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 20px;
  padding: 2.5rem;
  width: 90%;
  max-width: 400px;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  box-shadow: 0 25px 50px rgba(0,0,0,0.4);
}

.login-modal-box h3 {
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0;
  background: linear-gradient(135deg, #667eea, #a78bfa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.login-modal-box p {
  color: rgba(255,255,255,0.55);
  font-size: 0.9rem;
  margin: 0;
}

.login-modal-box input {
  width: 100%;
  padding: 1rem;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  font-size: 1rem;
  background: rgba(255,255,255,0.08);
  color: #fff;
  outline: none;
  transition: all 0.3s;
  box-sizing: border-box;
}
.login-modal-box input::placeholder { color: rgba(255,255,255,0.35); }
.login-modal-box input:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 3px rgba(102,126,234,0.2);
}

.login-modal-box-actions {
  display: flex;
  gap: 1rem;
}

.login-button {
  flex: 1;
  padding: 0.85rem;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
  border-radius: 12px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
}
.login-button:hover { opacity: 0.9; transform: translateY(-2px); }

.back-button {
  flex: 1;
  padding: 0.85rem;
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.7);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s;
}
.back-button:hover { background: rgba(255,255,255,0.13); }

@media (max-width: 480px) {
  .login-container {
    align-items: flex-start;
    padding: 1rem 0;
  }

  .login-form {
    padding: 2rem 1.25rem;
    margin: 1rem;
    border-radius: 16px;
    max-width: 100%;
  }

  .login-logo {
    height: 60px;
    margin-bottom: 1rem;
  }

  .login-form h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .login-form input {
    padding: 0.85rem;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .login-form button[type="submit"] {
    padding: 0.85rem;
    font-size: 1rem;
  }

  .google-btn {
    font-size: 0.85rem;
    padding: 0.75rem;
  }

  .toggle-form {
    font-size: 0.85rem;
    margin-top: 1rem;
  }

  .login-toast {
    top: 1rem;
    width: calc(100% - 2rem);
    font-size: 0.85rem;
    padding: 0.85rem 1rem;
  }

  .login-modal-box {
    padding: 1.5rem 1.25rem;
    margin: 1rem;
    border-radius: 16px;
  }

  .login-modal-box h3 { font-size: 1.3rem; }

  .login-modal-box-actions {
    flex-direction: column;
  }

  .login-modal-box-actions button {
    width: 100%;
  }

  .password-strength {
    font-size: 0.75rem;
  }
}

